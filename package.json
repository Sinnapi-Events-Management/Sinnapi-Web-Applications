{
  "name": "sinnapi",
  "private": true,
  "version": "0.0.0",
  "description": "Sinnapi — event marketplace monorepo (public site + client/vendor/admin portals).",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:all": "turbo run dev",
    "dev": "turbo run dev",
    "dev:web": "yarn workspace @sinnapi/web-public dev",
    "dev:client": "yarn workspace @sinnapi/client-portal dev",
    "dev:vendor": "yarn workspace @sinnapi/vendor-portal dev",
    "dev:admin": "yarn workspace @sinnapi/admin-portal dev",
    "dev:portals": "turbo run dev --filter=@sinnapi/client-portal --filter=@sinnapi/vendor-portal --filter=@sinnapi/admin-portal",
    "build": "turbo run build",
    "build:all": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "verify": "yarn typecheck && yarn lint && yarn format:check",
    "prepare": "husky",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "format:web": "yarn workspace @sinnapi/web-public format",
    "format:client": "yarn workspace @sinnapi/client-portal format",
    "format:vendor": "yarn workspace @sinnapi/vendor-portal format",
    "format:admin": "yarn workspace @sinnapi/admin-portal format",
    "format:ui": "yarn workspace @sinnapi/ui format",
    "format:repo": "prettier --write .",
    "start:web": "yarn workspace @sinnapi/web-public start",
    "setup:env": "for d in apps/*/; do if [ -f \"$d.env.example\" ] && [ ! -f \"$d.env.local\" ]; then cp \"$d.env.example\" \"$d.env.local\" && echo \"created ${d}.env.local\"; fi; done; echo 'env ready (fill in your Supabase keys)'",
    "clean": "find apps -type d \\( -name dist -o -name .next -o -name .turbo \\) -prune -exec rm -rf {} + ; rm -rf .turbo",
    "clean:deps": "rm -rf node_modules apps/*/node_modules",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "functions:serve": "supabase functions serve"
  },
  "devDependencies": {
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-check-file": "2.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3"
  },
  "resolutions": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "@mui/material": "5.18.0",
    "@mui/icons-material": "5.18.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1"
  }
}
