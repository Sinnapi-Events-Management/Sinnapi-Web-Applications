# Vite exposes only VITE_-prefixed vars to the client (anon key is safe by design)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge Functions base URL (used to trigger payouts, etc.)
VITE_FUNCTIONS_URL=https://your-project-ref.functions.supabase.co
